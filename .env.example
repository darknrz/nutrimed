# ============================================================
# NutriMed - Plantilla de Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=nutrimed
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_seguro_aqui

# ── Spring Datasource ──────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nutrimed
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=tu_password_seguro_aqui

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=tu_jwt_secret_minimo_256_bits

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=tu_google_client_id
GOOGLE_OAUTH_CLIENT_ID_ANDROID=tu_google_client_id_android

# ── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_UPLOAD_PRESET=tu_upload_preset
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret

# ── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=tu_groq_api_key

# ── Gemini ──────────────────────────────────────────────────
GEMINI_API_KEY=tu_gemini_api_key

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=tu_anthropic_api_key
